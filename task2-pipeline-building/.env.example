# GCP Project Coordinates
GCP_PROJECT_ID="your-gcp-project-id"
BQ_DATASET="your_bigquery_dataset_name"

# Google Application Credentials for authentication
# Set this to the absolute or relative path to your service account key file (do not commit the actual JSON key file to git)
GOOGLE_APPLICATION_CREDENTIALS="path/to/your/service_account.json"

# Alerting SMTP Configs (Mocking is enabled by default to run without active SMTP credentials)
SMTP_SERVER="smtp.yourmailserver.com"
SMTP_PORT=587
SMTP_USER="your-email@domain.com"
SMTP_PASSWORD="your-email-password"
ALERT_RECEIVER_EMAIL="receiver-email@domain.com"
ALERT_SENDER_EMAIL="sender-email@domain.com"
MOCK_ALERTING="true"
